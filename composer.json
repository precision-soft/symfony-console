{
    "name": "precision-soft/symfony-console",
    "type": "symfony-bundle",
    "description": "Symfony bundle for generating cron, Supervisor, and Kubernetes configuration files",
    "keywords": [
        "symfony",
        "console",
        "cronjob",
        "worker",
        "supervisor",
        "kubernetes",
        "crontab"
    ],
    "homepage": "https://github.com/precision-soft/symfony-console",
    "license": "MIT",
    "authors": [
        {
            "name": "Adrian Jeledintan",
            "email": "adrian.jeledintan@precision-soft.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/filesystem": "^7.0",
        "symfony/http-kernel": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.*",
        "phpstan/phpstan": "^2.0",
        "precision-soft/symfony-phpunit": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\Console\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\Console\\Test\\": "tests/"
        }
    },
    "scripts": {
        "install-hooks": [
            "[ \"$COMPOSER_DEV_MODE\" -eq 1 ] && rm -rf .git/hooks && ln -s ../.dev/git-hooks .git/hooks || exit 0"
        ],
        "post-install-cmd": [
            "@install-hooks"
        ],
        "post-update-cmd": [
            "@install-hooks"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
